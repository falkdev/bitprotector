# Backend API URL (production: served from same origin, no CORS needed)
VITE_API_BASE_URL=https://localhost:8443/api/v1

# Database path (used by the "Run Backup Now" action in DatabaseBackupsPage)
VITE_DB_PATH=/var/lib/bitprotector/bitprotector.db

# Development only — disable TLS certificate verification
VITE_DEV_INSECURE=false
